{
  "servers": [
    {
      "name": "filesystem",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/Users/qiang.lilq/personal-system"],
      "enabled": false
    },
    {
      "name": "fetch",
      "transport": "stdio",
      "command": "uvx",
      "args": ["mcp-server-fetch"],
      "enabled": false
    },
    {
      "name": "wiki-search",
      "transport": "stdio",
      "command": "uv",
      "args": ["--directory", "../personal-tools/archive/wiki-search", "run", "wiki-search-mcp"],
      "env": {
        "WIKI_SEARCH_API_URL": "http://127.0.0.1:8080"
      },
      "enabled": false
    },
    {
      "name": "http-example",
      "transport": "http",
      "url": "http://localhost:3000/mcp",
      "enabled": false
    }
  ]
}
