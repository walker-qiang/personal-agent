# ============================================================
# Project Matrix 环境变量
# 复制为 .env 并填入实际值
# 兼容 personal-os 的 PERSONAL_OS_* 环境变量
# ============================================================

# Agent 绑定地址（默认 127.0.0.1:7101）
# MATRIX_AGENT_ADDR=127.0.0.1:7101
# 兼容 personal-os: PERSONAL_OS_AGENT_ADDR=127.0.0.1:7101

# Finance SQLite cache 路径
# MATRIX_CACHE_PATH=var/cache/finance.sqlite
# 兼容 personal-os: PERSONAL_OS_CACHE_PATH=/path/to/personal-os/var/cache/finance.sqlite

# Trace 日志路径
# MATRIX_TRACE_PATH=var/agent/tool-calls.jsonl
# 兼容 personal-os: PERSONAL_OS_AGENT_TRACE_PATH=/path/to/tool-calls.jsonl

# LLM Provider: deepseek | anthropic | agnes
AGENT_PROVIDER=agnes

# API Keys
DEEPSEEK_API_KEY=your-deepseek-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key
# AGNES_API_KEY=your-agnes-api-key

# Model（可选，默认值见下）
# AGENT_MODEL=deepseek-chat
# AGENT_MAX_TOKENS=1200
# AGENT_MODEL_TIMEOUT_SEC=45

# DeepSeek Base URL（可选，默认 https://api.deepseek.com）
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Agnes Base URL（可选，默认 https://apihub.agnes-ai.com/v1）
# AGNES_BASE_URL=https://apihub.agnes-ai.com/v1

# 会话记忆轮数
# MEMORY_MAX_TURNS=8

# ============================================================
# Multi-user authentication
# ============================================================
# JWT_SECRET: 必填，用于签名 JWT token（生成: openssl rand -hex 32）
JWT_SECRET=change-me-to-a-random-secret

# ADMIN_PASSWORD: 可选，仅首次启动时用于自动创建 admin 用户
# 如果未设置且数据库中无用户，启动时会打印警告，需要通过 API 手动创建用户
# ADMIN_PASSWORD=your-admin-password

# ============================================================
# MCP (Model Context Protocol) Client
# ============================================================
# MCP 配置文件路径（默认: config/mcp_servers.json）
# 配置文件不存在时跳过 MCP 初始化，不影响正常运行
# MCP_CONFIG_PATH=config/mcp_servers.json

# 安装 MCP 支持: pip install -e ".[mcp]" 或 pip install mcp>=1.27.0

# ============================================================
# Code Execution Sandbox
# ============================================================
# 启用代码执行沙箱（默认关闭）
# MATRIX_CODE_SANDBOX_ENABLED=true
# 执行超时（秒，默认 30）
# MATRIX_CODE_SANDBOX_TIMEOUT_SEC=30
# 内存限制（MB，默认 512）
# MATRIX_CODE_SANDBOX_MAX_MEMORY_MB=512
# 输出截断长度（字符数，默认 10000）
# MATRIX_CODE_SANDBOX_MAX_OUTPUT_CHARS=10000
# 沙箱内允许网络访问（默认 false）
# MATRIX_CODE_SANDBOX_NETWORK=false